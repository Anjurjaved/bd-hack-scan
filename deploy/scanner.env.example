# BD Hack-Audit — scanner/harvester runtime secrets (copy to scanner.env, fill in).
# scanner.env is gitignored — NEVER commit real secrets.

# Worker API base (already live on Cloudflare — leave as-is)
API_BASE=https://bd-hack-audit-api.javed-it.workers.dev

# Shared bearer token — from your Mac: ~/.secrets/bd_hack_audit.env  (SHARED_TOKEN=...)
SHARED_TOKEN=PUT_YOUR_SHARED_TOKEN_HERE

# Groq key pool for Stage-2 LLM verify (comma-separated). From ~/.secrets/groq_keys.env
GROQ_API_KEY=gsk_key1,gsk_key2,gsk_key3

# --- tunables (sane defaults; override if you want) ---
SCAN_WORKERS=6        # parallel scan.py processes (ARM A1 4-OCPU handles 6 easily)
SCAN_CONC=50          # async domain fetches per worker
VERIFY_CONC=8         # parallel Groq calls per worker
DOMAIN_TIMEOUT=90
JOB_MINUTES=25        # each worker scans this long, then restarts (claims fresh batches)
VERIFY_PROVIDER=groq
